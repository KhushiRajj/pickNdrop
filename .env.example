# ─── S3 / Supabase S3 Storage ─────────────────────────────────
# For standard AWS S3, leave S3_ENDPOINT blank.
# For Supabase S3 Storage:
# - AWS_REGION: Your project region (e.g. ap-southeast-1)
# - S3_ENDPOINT: https://<project-ref>.storage.supabase.co/storage/v1/s3
# - AWS_ACCESS_KEY_ID & AWS_SECRET_ACCESS_KEY: Get from Supabase -> Project Settings -> Storage
AWS_REGION=us-east-1
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
S3_BUCKET_NAME=your_bucket_name_here

# ─── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── App ──────────────────────────────────────────────────────
# Local dev:  http://localhost:3001
# Production: https://your-app.vercel.app
BASE_URL=http://localhost:3001

# CORS allowed origin (set to your Vercel URL in production)
ALLOWED_ORIGIN=http://localhost:5173

PORT=3001
NODE_ENV=development
